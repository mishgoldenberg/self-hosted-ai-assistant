# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Your numeric Telegram user ID (message @userinfobot to find it)
TELEGRAM_USER_ID=123456789

# Default city for weather lookups (overridable at runtime with /weather setdefault <city>)
DEFAULT_CITY=London

# Your local timezone (e.g. America/New_York, Europe/London, Asia/Tokyo)
# Used to interpret relative times like "tomorrow at 9am" in reminders
TIMEZONE=Europe/London
